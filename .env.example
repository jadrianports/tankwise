# Database configuration. Leave DB_* unset to run against a local SQLite
# file (config/settings/base.py defaults to that automatically).
DB_ENGINE=
DB_NAME=
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_PORT=

# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=

# Mapbox
MAPBOX_TOKEN=

# Cache (django-redis in Docker, local fallback)
CACHE_BACKEND=
REDIS_URL=
CACHE_TTL_SECONDS=
