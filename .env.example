# Copy this file to .env (cp .env.example .env). For the Docker Compose demo,
# MAPBOX_TOKEN below is the ONLY value you need to set -- docker-compose.yml
# already provides the container-critical vars (DJANGO_DEBUG, DJANGO_ALLOWED_HOSTS,
# CACHE_BACKEND, REDIS_URL, DB_NAME) in its `environment:` block. Every other key
# here is commented out so it stays ABSENT and config/settings/base.py applies its
# built-in default; uncomment and set one only if you want to override that default
# (e.g. running manage.py directly outside Docker).

# --- Mapbox (the one value to fill for the demo) ---
# Without a token the stack still boots and the SPA loads; a /api/route call
# returns a clear 502 "Map service unavailable" until a token is set.
MAPBOX_TOKEN=

# --- Django ---
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=*

# --- Database ---
# Leave DB_* unset to run against a local SQLite file (the default).
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_PORT=

# --- Corridor tuning ---
# CORRIDOR_ROOFTOP_MI=5
# CORRIDOR_CITY_MI=20

# --- Cache (django-redis in Docker, locmem fallback locally) ---
# CACHE_BACKEND=locmem
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=86400
