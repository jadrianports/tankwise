# Copy this file to .env (cp .env.example .env). For the Docker Compose demo,
# MAPBOX_TOKEN below is the ONLY value you need to set -- docker-compose.yml
# already provides the container-critical vars (DJANGO_DEBUG, DJANGO_ALLOWED_HOSTS,
# CACHE_BACKEND, REDIS_URL, DB_NAME) in its `environment:` block. Every other key
# here is commented out so it stays ABSENT and config/settings/base.py applies its
# built-in default; uncomment and set one only if you want to override that default
# (e.g. running manage.py directly outside Docker).
#
# The production-only groups below (database TLS/host tuning, HSTS, rate
# limiting, gunicorn) are not needed for the local Docker demo -- they exist
# so the full env-var contract render.yaml declares is documented in one
# place. See render.yaml and the README's "Environment variables" table.

# --- Mapbox (the one value to fill for the demo) ---
# Without a token the stack still boots and the SPA loads; a /api/route call
# returns a clear 502 "Map service unavailable" until a token is set.
MAPBOX_TOKEN=

# --- Mapbox public token (browser-facing map_url) ---
# Public pk.* token used only to build the Static Images map_url returned by the API.
# Distinct from the secret MAPBOX_TOKEN above; an unset or non-pk. value raises
# ImproperlyConfigured. Restrict prod tokens by URL (Referer), but keep dev tokens
# unrestricted or a direct-open of map_url 403s. See README "Mapbox tokens".
MAPBOX_PUBLIC_TOKEN=

# --- Django ---
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=*

# --- Database ---
# Leave DB_* unset to run against a local SQLite file (the default).
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_PORT=

# --- Database tuning (Postgres/Neon only -- ignored for local SQLite) ---
# TLS mode for the Postgres connection; Neon requires TLS.
# DB_SSLMODE=require
# Persistent-connection lifetime in seconds. 0 (default) closes after each
# request, which is correct when a pooler (Neon's PgBouncer) already pools
# connections in front of Django -- stacking Django's own reuse on top of an
# external pooler would be a second, redundant pooling layer.
# DB_CONN_MAX_AGE=0
# Verifies a reused persistent connection is still alive before use.
# DB_CONN_HEALTH_CHECKS=True
# Neon's direct (non-pooled) endpoint. entrypoint.sh runs `migrate --noinput`
# against this host instead of DB_HOST when it's set, because transaction-mode
# connection pooling is documented as error-prone for schema migrations. Every
# other step (seed, gunicorn) still uses the pooled DB_HOST above.
# DB_MIGRATE_HOST=

# --- Corridor tuning ---
# CORRIDOR_ROOFTOP_MI=5
# CORRIDOR_CITY_MI=20

# --- Cache (django-redis in Docker, locmem fallback locally) ---
# CACHE_BACKEND=locmem
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=86400

# --- Fuel price dataset vintage (display-only metadata) ---
# Qualifies every price/cost figure the API returns. Not a live
# quote -- see FUEL_PRICE_DATA_NOTE for the full caveat shipped in
# the JSON payload itself.
# FUEL_PRICE_AS_OF=2025-01-01
# FUEL_PRICE_DATA_NOTE=

# --- Rate limiting (POST /api/route only -- everything else is unthrottled) ---
# Burst ceiling.
# ROUTE_THROTTLE_BURST_RATE=20/min
# Sustained daily ceiling.
# ROUTE_THROTTLE_SUSTAINED_RATE=200/day

# --- Production hosting (Render) ---
# HSTS duration in seconds (1 year). Only takes effect under
# config.settings.production, which always sets DEBUG=False and enforces
# HTTPS.
# SECURE_HSTS_SECONDS=31536000
# Number of trusted reverse-proxy hops DRF's throttle should exclude when
# reading X-Forwarded-For to find the real client IP. 1 matches Render's
# single edge proxy.
# NUM_PROXIES=1

# --- gunicorn tuning (production; entrypoint.sh reads these, with the same
# defaults shown here, when running under Docker/Render) ---
# Worker process count. 2 is measurement-backed against Render free's 512 MB
# limit -- see entrypoint.sh's own comment.
# WEB_CONCURRENCY=2
# Per-request timeout in seconds.
# GUNICORN_TIMEOUT=30
# Requests a worker handles before it's recycled, plus random jitter, to
# guard against slow memory creep.
# GUNICORN_MAX_REQUESTS=500
# GUNICORN_MAX_REQUESTS_JITTER=50
